# Public API base used by marketplace, auth, booking, leads and billing.
VITE_API_URL=https://api.allop.es/api

# Optional explicit health URL used by `npm run predeploy:health`.
# If empty, the script checks `${VITE_API_URL}/health`.
VITE_HEALTH_CHECK_URL=https://api.allop.es/api/health

# Optional privacy-first analytics.
VITE_PLAUSIBLE_DOMAIN=allop.es

# Optional frontend error forwarding endpoint.
VITE_MONITORING_ENDPOINT=

# Optional Sentry DSN if Sentry is enabled instead of/in addition to custom monitoring.
VITE_SENTRY_DSN=

# Optional Google OAuth entrypoint for client auth.
VITE_GOOGLE_AUTH_URL=
